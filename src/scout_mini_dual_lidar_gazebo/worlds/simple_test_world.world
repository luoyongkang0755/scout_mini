<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="simple_test_world">
    <!-- Physics: values from ugv_gazebo_sim/scout/scout_gazebo_sim/worlds/weston_robot_empty.world -->
    <physics type="ode">
      <max_step_size>0.005</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>200</real_time_update_rate>
      <gravity>0 0 -9.8</gravity>
      <ode>
        <solver>
          <type>quick</type>
          <iters>30</iters>
          <sor>1.0</sor>
        </solver>
      </ode>
    </physics>

    <!-- Scene settings -->
    <scene>
      <ambient>0.5 0.5 0.5 1</ambient>
      <background>0.8 0.8 0.8 1</background>
      <shadows>false</shadows>
    </scene>


    <!-- Load sensors system for LiDAR and other sensors -->
    <plugin filename="ignition-gazebo-sensors-system" name="gz::sim::systems::Sensors">
      <rendering>false</rendering>
      <sensor_update_rate>5</sensor_update_rate>
    </plugin>
    <!-- IMU system plugin -->
    <plugin filename="ignition-gazebo-imu-system" name="ignition::gazebo::systems::Imu">
    </plugin> 
    <!-- Scene Broadcaster for GUI rendering -->
    <plugin filename="ignition-gazebo-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster">
    </plugin>

    <!-- User Commands for model manipulation and spawn -->
    <plugin filename="ignition-gazebo-user-commands-system" name="gz::sim::systems::UserCommands">
    </plugin>

    <!-- Contact system for collision detection and friction -->
    <plugin filename="ignition-gazebo-contact-system" name="gz::sim::systems::Contact">
    </plugin>

    <!-- Physics system - required for diff drive to work -->
    <plugin filename="ignition-gazebo-physics-system" name="gz::sim::systems::Physics">
    </plugin>
    
    <!-- Ground plane -->
    <model name="ground_plane">
      <static>true</static>
      <pose>0 0 -0.001 0 0 0</pose>
      <link name="ground">
        <collision name="ground_plane_collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>50 50</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>100</mu>
                <mu2>50</mu2>
              </ode>
            </friction>
            <bounce/>
            <contact>
              <ode/>
            </contact>
          </surface>
          <max_contacts>10</max_contacts>
        </collision>
        <visual name="ground_plane_visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>50 50</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.5 0.7 0.5 1</ambient>
            <diffuse>0.5 0.7 0.5 1</diffuse>
            <specular>0 0 0 1</specular>
          </material>
        </visual>
        <velocity_decay>
          <linear>0</linear>
          <angular>0</angular>
        </velocity_decay>
        <self_collide>0</self_collide>
        <kinematic>0</kinematic>
        <gravity>1</gravity>
      </link>
    </model>

    <!-- Sun -->
    <light type="directional" name="sun">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.5 -0.5</direction>
    </light>

    <!-- Outer Wall - North -->
    <model name="wall_north">
      <static>true</static>
      <pose>0 8.0 0.75 0 0 0</pose>
      <link name="wall_north_link">
        <collision name="wall_north_collision">
          <geometry>
            <box>
              <size>16.0 0.3 1.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="wall_north_visual">
          <geometry>
            <box>
              <size>16.0 0.3 1.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.6 0.6 0.6 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Outer Wall - South -->
    <model name="wall_south">
      <static>true</static>
      <pose>0 -8.0 0.75 0 0 0</pose>
      <link name="wall_south_link">
        <collision name="wall_south_collision">
          <geometry>
            <box>
              <size>16.0 0.3 1.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="wall_south_visual">
          <geometry>
            <box>
              <size>16.0 0.3 1.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.6 0.6 0.6 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Outer Wall - East -->
    <model name="wall_east">
      <static>true</static>
      <pose>8.0 0 0.75 0 0 0</pose>
      <link name="wall_east_link">
        <collision name="wall_east_collision">
          <geometry>
            <box>
              <size>0.3 16.0 1.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="wall_east_visual">
          <geometry>
            <box>
              <size>0.3 16.0 1.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.6 0.6 0.6 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Outer Wall - West -->
    <model name="wall_west">
      <static>true</static>
      <pose>-8.0 0 0.75 0 0 0</pose>
      <link name="wall_west_link">
        <collision name="wall_west_collision">
          <geometry>
            <box>
              <size>0.3 16.0 1.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="wall_west_visual">
          <geometry>
            <box>
              <size>0.3 16.0 1.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.6 0.6 0.6 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Obstacle Box 1 - Front Center (Red) -->
    <model name="obstacle_box_1">
      <static>true</static>
      <pose>4.0 0.0 0.5 0 0 0</pose>
      <link name="obstacle_box_1_link">
        <collision name="obstacle_box_1_collision">
          <geometry>
            <box>
              <size>1.0 1.0 1.0</size>
            </box>
          </geometry>
        </collision>
        <visual name="obstacle_box_1_visual">
          <geometry>
            <box>
              <size>1.0 1.0 1.0</size>
            </box>
          </geometry>
          <material>
            <ambient>0.8 0.2 0.2 1</ambient>
            <diffuse>0.8 0.2 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

  

    <!-- Obstacle Box 3 - Right Side (Blue) -->
    <model name="obstacle_box_3">
      <static>true</static>
      <pose>0.0 -4.0 0.4 0 0 0</pose>
      <link name="obstacle_box_3_link">
        <collision name="obstacle_box_3_collision">
          <geometry>
            <box>
              <size>1.2 0.6 0.8</size>
            </box>
          </geometry>
        </collision>
        <visual name="obstacle_box_3_visual">
          <geometry>
            <box>
              <size>1.2 0.6 0.8</size>
            </box>
          </geometry>
          <material>
            <ambient>0.2 0.2 0.8 1</ambient>
            <diffuse>0.2 0.2 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Obstacle Box 4 - Behind (Yellow) -->
    <model name="obstacle_box_4">
      <static>true</static>
      <pose>-4.0 0.0 0.6 0 0 0</pose>
      <link name="obstacle_box_4_link">
        <collision name="obstacle_box_4_collision">
          <geometry>
            <box>
              <size>0.8 1.5 1.2</size>
            </box>
          </geometry>
        </collision>
        <visual name="obstacle_box_4_visual">
          <geometry>
            <box>
              <size>0.8 1.5 1.2</size>
            </box>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.2 1</ambient>
            <diffuse>0.8 0.8 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Obstacle Box 5 - Front Left (Purple) -->
    <model name="obstacle_box_5">
      <static>true</static>
      <pose>3.0 3.0 0.4 0 0 0</pose>
      <link name="obstacle_box_5_link">
        <collision name="obstacle_box_5_collision">
          <geometry>
            <box>
              <size>0.7 0.7 0.8</size>
            </box>
          </geometry>
        </collision>
        <visual name="obstacle_box_5_visual">
          <geometry>
            <box>
              <size>0.7 0.7 0.8</size>
            </box>
          </geometry>
          <material>
            <ambient>0.8 0.2 0.8 1</ambient>
            <diffuse>0.8 0.2 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>



    <!-- Navigation Waypoint Marker 1 -->
    <model name="waypoint_1">
      <static>true</static>
      <pose>5.0 5.0 0.05 0 0 0</pose>
      <link name="waypoint_1_link">
        <collision name="waypoint_1_collision">
          <geometry>
            <box>
              <size>0.2 0.2 0.1</size>
            </box>
          </geometry>
        </collision>
        <visual name="waypoint_1_visual">
          <geometry>
            <box>
              <size>0.2 0.2 0.1</size>
            </box>
          </geometry>
          <material>
            <ambient>0.0 1.0 0.0 1</ambient>
            <diffuse>0.0 1.0 0.0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Navigation Waypoint Marker 2 -->
    <model name="waypoint_2">
      <static>true</static>
      <pose>-5.0 -5.0 0.05 0 0 0</pose>
      <link name="waypoint_2_link">
        <collision name="waypoint_2_collision">
          <geometry>
            <box>
              <size>0.2 0.2 0.1</size>
            </box>
          </geometry>
        </collision>
        <visual name="waypoint_2_visual">
          <geometry>
            <box>
              <size>0.2 0.2 0.1</size>
            </box>
          </geometry>
          <material>
            <ambient>0.0 0.0 1.0 1</ambient>
            <diffuse>0.0 0.0 1.0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>