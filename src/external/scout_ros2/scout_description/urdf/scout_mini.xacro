<?xml version="1.0"?>

<robot name="scout_mini"
    xmlns:xacro="http://ros.org/wiki/xacro">

    <xacro:arg name="robot_namespace" default="/" />
    <xacro:arg name="urdf_extras" default="empty.urdf" />

    <xacro:include filename="$(find scout_description)/urdf/scout_mini_wheel_1.xacro" />
    <xacro:include filename="$(find scout_description)/urdf/scout_mini_wheel_2.xacro" />
    <xacro:include filename="$(find scout_description)/urdf/scout_mini_wheel_3.xacro" />
    <xacro:include filename="$(find scout_description)/urdf/scout_mini_wheel_4.xacro" />    


    <!-- Variables -->
    <xacro:property name="M_PI" value="3.14159"/>

    <!-- Vehicle Geometries - Scout Mini dimensions -->
    <xacro:property name="base_x_size" value="0.6200000" />
    <xacro:property name="base_y_size" value="0.5800000" />
    <xacro:property name="base_z_size" value="0.2350000" />

    <xacro:property name="wheelbase" value="0.3132556" />
    <xacro:property name="track" value="0.4563536" />
    <xacro:property name="wheel_vertical_offset" value="-0.077" />
    <xacro:property name="wheel_diameter" value="0.16" />
    <xacro:property name="wheel_width" value="0.084" />
    
    <!-- Calibrated wheel radius: adjusted from 0.145 → 0.085 → 0.064 → 0.058
         Gazebo 90° ↔ RViz 100° implies wheel_radius still 100/90 = 1.11x too large. -->
    <!-- Wheel radius restored to real value (0.145). Friction/torque fixes resolved rotation lag. -->
    <xacro:property name="wheel_radius" value="1.600e-01" />
    <xacro:property name="wheel_length" value="0.8e-01" />

    <!-- Base link -->
    <link name="base_link">
        <visual>
            <origin xyz="0.015 0.0231316650320557 0" rpy="0 0 0"/>

            <geometry>
                <mesh filename="package://scout_description/meshes/scout_mini_base_link.dae" />
            </geometry>
        </visual>
        <collision>
            <origin xyz="0.015 0.0231316650320557 0.008" rpy="0 0 0" />
            <geometry>
                <mesh
                    filename="package://scout_description/meshes/scout_mini_base_link.dae" />
            </geometry>
        </collision>
    </link>

    <link name="inertial_link">
        <inertial>
            <mass value="132.3898489950015" />
            <origin xyz="0.015 0.0231316650320557 0" />
            <inertia ixx="0.185196122711036"
            ixy="4.30144213829512E-08"
            ixz="5.81037523686401E-08"
            iyy="0.364893736238929"
            iyz="-0.000386720198091934"
            izz="0.223868521722778" />
        </inertial>
    </link>

    <joint name="inertial_joint" type="fixed">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="inertial_link" />
    </joint>

    <xacro:scout_mini_wheel_1 wheel_prefix="front_left" wheel_diameter="${wheel_diameter}" wheel_width="${wheel_width}">
        <origin xyz="${wheelbase/2} ${track/2} ${wheel_vertical_offset}" rpy="-1.57 0 0"/>
    </xacro:scout_mini_wheel_1>

    <xacro:scout_mini_wheel_2 wheel_prefix="front_right" wheel_diameter="${wheel_diameter}" wheel_width="${wheel_width}">
        <origin xyz="${wheelbase/2} ${-track/2} ${wheel_vertical_offset}" rpy="-1.57 0 0"/>
    </xacro:scout_mini_wheel_2>

    <xacro:scout_mini_wheel_3 wheel_prefix="rear_left" wheel_diameter="${wheel_diameter}" wheel_width="${wheel_width}">
        <origin xyz="${-wheelbase/2} ${track/2} ${wheel_vertical_offset}" rpy="1.57 0 0"/>
    </xacro:scout_mini_wheel_3>

    <xacro:scout_mini_wheel_4 wheel_prefix="rear_right" wheel_diameter="${wheel_diameter}" wheel_width="${wheel_width}">
        <origin xyz="${-wheelbase/2} ${-track/2} ${wheel_vertical_offset}" rpy="1.57 0 0"/>    
    </xacro:scout_mini_wheel_4>

    <xacro:include filename="$(arg urdf_extras)" />
    <xacro:include filename="$(find scout_description)/urdf/scout_mini.gazebo" />
</robot>
