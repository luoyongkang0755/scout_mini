<?xml version="1.0"?>

<robot xmlns:xacro="http://ros.org/wiki/xacro">

    <!-- ============================================================ -->
    <!-- Wheel friction: prevent slip so DiffDrive odometry matches   -->
    <!-- ============================================================ -->
    <gazebo reference="front_left_wheel_link">
        <mu1>0.2</mu1>
        <mu2>0.2</mu2>
        <kp>10000000.0</kp>
        <kd>1.0</kd>
        <fdir1>1 0 0</fdir1>
        <minDepth>0.001</minDepth>
        <maxContacts>64</maxContacts>
    </gazebo>
    <gazebo reference="front_right_wheel_link">
        <mu1>0.2</mu1>
        <mu2>0.2</mu2>
        <kp>10000000.0</kp>
        <kd>1.0</kd>
        <fdir1>1 0 0</fdir1>
        <minDepth>0.001</minDepth>
        <maxContacts>64</maxContacts>
    </gazebo>
    <gazebo reference="rear_left_wheel_link">
        <mu1>0.2</mu1>
        <mu2>0.2</mu2>
        <kp>10000000.0</kp>
        <kd>1.0</kd>
        <fdir1>1 0 0</fdir1>
        <minDepth>0.001</minDepth>
        <maxContacts>64</maxContacts>
    </gazebo>
    <gazebo reference="rear_right_wheel_link">
        <mu1>0.2</mu1>
        <mu2>0.2</mu2>
        <kp>10000000.0</kp>
        <kd>1.0</kd>
        <fdir1>1 0 0</fdir1>
        <minDepth>0.001</minDepth>
        <maxContacts>64</maxContacts>
    </gazebo>

    <!-- ============================================================ -->
    <!-- Gazebo differential drive plugin                             -->
    <!-- ============================================================ -->
    <gazebo>
        <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
            <left_joint>front_left_wheel</left_joint>
            <left_joint>rear_left_wheel</left_joint>
            <right_joint>front_right_wheel</right_joint>
            <right_joint>rear_right_wheel</right_joint>
            <wheel_separation>${track}</wheel_separation>
            <wheel_radius>0.16</wheel_radius>
            <max_wheel_torque>1000.0</max_wheel_torque>
            <max_linear_acceleration>1.0</max_linear_acceleration>
            <max_angular_acceleration>6.0</max_angular_acceleration>
            <topic>/cmd_vel</topic>
            <odom_topic>/odom</odom_topic>
            <tf_topic>/tf</tf_topic>
            <odom_publish_frequency>100</odom_publish_frequency>
            <odom_frame>odom</odom_frame>
            <robot_base_frame>base_link</robot_base_frame>
            <max_linear_velocity>2.0</max_linear_velocity>
            <max_angular_velocity>3.0</max_angular_velocity>
        </plugin>
    </gazebo>

    <!-- ============================================================ -->
    <!-- Gazebo joint state publisher                                 -->
    <!-- ============================================================ -->
    <gazebo>
        <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
            <topic>/joint_states</topic>
        </plugin>
    </gazebo>

</robot>
